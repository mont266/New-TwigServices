rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        // The default admin is the user who created the app
        (request.auth.token.email == "scottmontford@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'description', 'thumbnail', 'category', 'cpdUnits', 'totalTime', 'price', 'purchaseLink', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 2000 &&
             isValidUrl(data.thumbnail) && data.thumbnail.size() <= 1000 &&
             data.category in ['Health & Safety', 'HR & Business Skills', 'Health and Social Care'] &&
             data.cpdUnits is number && data.cpdUnits >= 0 &&
             data.totalTime is string && data.totalTime.size() > 0 && data.totalTime.size() <= 50 &&
             data.price is number && data.price >= 0 &&
             isValidUrl(data.purchaseLink) && data.purchaseLink.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /courses/{courseId} {
      // Anyone can read courses
      allow read: if true;
      // Only admins can create, update, or delete courses
      allow create: if isAdmin() && isValidCourse(request.resource.data);
      allow update: if isAdmin() && isValidCourse(request.resource.data) && 
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Only admins can create or update roles
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
